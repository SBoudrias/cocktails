{
  "name": "cocktails-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "yarn workspace @cocktails/web dev",
    "lint": "yarn workspaces foreach -A run lint && eslint . && oxfmt . --check",
    "test": "vitest --run --coverage",
    "check-data": "turbo run check-data --filter=@cocktails/data",
    "youtube-sync": "yarn workspace @cocktails/youtube-sync youtube-sync",
    "prepare": "git config --local include.path ../.gitconfig || true"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.6",
    "@types/json-schema": "^7.0.15",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.8.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser": "^4.1.6",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.4.0",
    "eslint-config-next": "16.2.6",
    "nano-staged": "^1.0.2",
    "oxfmt": "^0.50.0",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  },
  "nano-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern",
    "packages/data/data/**/*.json": "yarn check-data",
    "*.m?[jt]sx?": "eslint . --fix"
  },
  "volta": {
    "node": "24.13.0"
  },
  "packageManager": "yarn@4.12.0+sha512.f45ab632439a67f8bc759bf32ead036a1f413287b9042726b7cc4818b7b49e14e9423ba49b18f9e06ea4941c1ad062385b1d8760a8d5091a1a31e5f6219afca8"
}
