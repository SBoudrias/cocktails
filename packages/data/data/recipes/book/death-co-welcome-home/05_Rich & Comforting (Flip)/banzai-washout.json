  "name": "Banzai Washout",
  "preparation": "shaken",
  "served_on": "crushed ice",
  "glassware": "goblet",
  "ingredients": [
    {
      "name": "Pineapple juice",
      "type": "juice",
      "quantity": {
        "amount": 0.5,
        "unit": "oz"
      }
    },
    {
