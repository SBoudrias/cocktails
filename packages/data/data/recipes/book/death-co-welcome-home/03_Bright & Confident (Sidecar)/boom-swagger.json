{
  "$schema": "../../../../../schemas/recipe.schema.json",
  "name": "Boom Swagger",
  "preparation": "shaken",
  "served_on": "crushed ice",
  "glassware": "footed pilsner",
  "ingredients": [
    {
      "name": "Cane Sugar Syrup",
      "type": "syrup",
      "quantity": {
        "amount": 0.25,
        "unit": "oz"
      }
    },
    {
      "name": "House Ginger Syrup",
      "type": "syrup",
      "quantity": {
        "amount": 0.25,
        "unit": "oz"
      }
    },
    {
      "name": "Cinnamon syrup",
      "type": "syrup",
      "quantity": {
        "amount": 0.25,
        "unit": "oz"
      }
    },
    {
      "name": "Pineapple juice",
      "type": "juice",
      "quantity": {
        "amount": 0.5,
        "unit": "oz"
      }
    },
    {
      "name": "Lemon juice",
      "type": "juice",
      "quantity": {
        "amount": 0.75,
        "unit": "oz"
      }
    },
    {
      "name": "Lemon Hart 151",
      "type": "spirit",
      "quantity": {
        "amount": 0.25,
        "unit": "oz"
      }
    },
    {
      "name": "Lustau Amontillado Los Arcos Sherry",
      "type": "wine",
      "quantity": {
        "amount": 0.25,
        "unit": "oz"
      }
    },
    {
      "name": "Appleton Signature",
      "type": "spirit",
      "quantity": {
        "amount": 0.75,
        "unit": "oz"
      }
    },
    {
      "name": "Wild Turkey 101 Rye",
      "type": "spirit",
      "quantity": {
        "amount": 0.75,
        "unit": "oz"
      }
    }
  ],
  "instructions": [
    "Combine all the ingredients in a shaker and whip, shaking with a few pieces of crushed ice, just until incorporated. Dump into a pilsner glass and add crushed ice until about 80 percent full. Swizzle for a few seconds, then pack with more crushed ice, mounding it above the rim.",
    "Dash some Angostura bitters over the top, then dash some Peychaud's bitters over the pineapple wedge and garnish with the pineapple wedge. Serve with a straw."
  ],
