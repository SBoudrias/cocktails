{
  "$schema": "../../../../../schemas/recipe.schema.json",
  "name": "Firing Pin",
  "preparation": "shaken",
  "served_on": "crushed ice",
  "glassware": "footed pilsner",
  "ingredients": [
    {
      "name": "Cholula Hot Sauce",
      "type": "other",
      "quantity": {
        "amount": 1,
        "unit": "tsp"
      }
    },
    {
      "name": "Ginger syrup",
      "type": "syrup",
      "quantity": {
        "amount": 0.25,
        "unit": "oz"
      }
    },
    {
      "name": "Orgeat",
      "type": "category",
      "quantity": {
        "amount": 0.5,
        "unit": "oz"
      }
    },
    {
      "name": "Lime juice",
      "type": "juice",
      "quantity": {
        "amount": 1,
        "unit": "oz"
      }
    },
    {
      "name": "Sombra Mezcal",
      "type": "spirit",
      "quantity": {
        "amount": 2,
        "unit": "oz"
      }
    },
    {
      "name": "Campari",
      "type": "liqueur",
      "technique": {
        "technique": "application",
        "method": "float"
      },
      "quantity": {
        "amount": 0.5,
        "unit": "oz"
      }
    }
  ],
  "instructions": [
    "Combine all the ingredients except the Campari in a shaker and whip, shaking with a few pieces of crushed ice, just until incorporated. Dump into a pilsner glass and fill with crushed ice. Slowly pour the Campari over the back of a spoon to float it on top.",
    "Garnish with 1 mint bouquet."
  ],
