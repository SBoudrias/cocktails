  "name": "Voodoo Dreams",
  "preparation": "shaken",
  "served_on": "crushed ice",
  "glassware": "tiki",
  "ingredients": [
    {
      "name": "Saline",
      "type": "other",
      "quantity": {
        "amount": 0.5,
        "unit": "dash"
      }
    },
    {
      "name": "Bittermens Xocolatl Mole Bitters",
