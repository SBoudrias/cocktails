      "quantity": {
        "amount": 2,
        "unit": "dash"
      }
    },
    {
      "name": "Lemon juice",
      "type": "juice",
      "quantity": {
        "amount": 0.5,
        "unit": "oz"
      }
    },
    {
      "name": "Demerara syrup",
      "type": "syrup",
      "quantity": {
        "amount": 0.5,
        "unit": "oz"
      }
    },
    {
      "name": "Tempus Fugit crème de banane",
      "type": "liqueur",
      "quantity": {
        "amount": 0.5,
        "unit": "oz"
      }
    },
    {
      "name": "Diplomático Reserva Exclusiva",
