{
  "$schema": "../../../../../schemas/recipe.schema.json",
  "name": "El Fuerte",
  "preparation": "shaken",
  "served_on": "crushed ice",
  "glassware": "tiki",
  "ingredients": [
    {
      "name": "Bittermens Xocolatl Mole Bitters",
      "type": "bitter",
      "quantity": {
        "amount": 1,
        "unit": "dash"
      }
    },
    {
      "name": "Angostura bitters",
      "type": "bitter",
      "quantity": {
        "amount": 1,
        "unit": "dash"
      }
    },
    {
      "name": "Lemon juice",
      "type": "juice",
      "quantity": {
        "amount": 0.5,
        "unit": "oz"
      }
    },
    {
      "name": "Simple syrup",
      "type": "syrup",
      "quantity": {
        "amount": 0.5,
        "unit": "oz"
      }
    },
    {
      "name": "tepache",
      "type": "other",
      "quantity": {
        "amount": 2,
        "unit": "oz"
      }
    },
    {
      "name": "Giffard abricot du Roussillon",
      "type": "liqueur",
      "quantity": {
        "amount": 0.25,
        "unit": "oz"
      }
    },
    {
      "name": "Old Forester 100",
      "type": "spirit",
      "quantity": {
        "amount": 2,
        "unit": "oz"
      }
    }
  ],
  "instructions": [
    "Combine all the ingredients in a shaker and whip, shaking with a few pieces of crushed ice, just until incorporated. Dump into a tiki mug and add crushed ice until about 80 percent full. Swizzle for a few seconds, then pack with more crushed ice, mounding it above the rim.",
    "Grate some cinnamon over the top and serve with a straw."
  ],
