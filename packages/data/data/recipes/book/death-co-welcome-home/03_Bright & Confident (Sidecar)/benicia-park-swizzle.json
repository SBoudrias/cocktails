{
  "$schema": "../../../../../schemas/recipe.schema.json",
  "name": "Benicia Park Swizzle",
  "preparation": "shaken",
  "served_on": "crushed ice",
  "glassware": "footed pilsner",
  "ingredients": [
    {
      "name": "House Ginger Syrup",
      "type": "syrup",
      "quantity": {
        "amount": 0.5,
        "unit": "oz"
      }
    },
    {
      "name": "Lemon juice",
      "type": "juice",
      "quantity": {
        "amount": 0.75,
        "unit": "oz"
      }
    },
    {
      "name": "John D. Taylor's Velvet Falernum",
      "type": "liqueur",
      "quantity": {
        "amount": 0.25,
        "unit": "oz"
      }
    },
    {
      "name": "Highland Park 12 Year",
      "type": "spirit",
      "quantity": {
        "amount": 1,
        "unit": "oz"
      }
    },
    {
      "name": "Lustau Amontillado Los Arcos Sherry",
      "type": "wine",
      "quantity": {
        "amount": 1,
        "unit": "oz"
      }
    },
    {
      "name": "Giffard Muroise du Val de Loire",
      "type": "liqueur",
      "technique": {
        "technique": "application",
        "method": "float"
      },
      "quantity": {
        "amount": 0.5,
        "unit": "oz"
      }
    }
  ],
  "instructions": [
    "Combine the scotch, sherry, lemon juice, ginger syrup, and falernum in a shaker and whip, shaking with a few pieces of crushed ice, just until incorporated. Dump into a pilsner glass and add crushed ice until about 80 percent full. Swizzle for a few seconds, then pack with more crushed ice, mounding it above the rim. Slowly pour the Giffard Muroise over the back of a spoon to float it on top.",
    "Garnish with 1 mint leaf and serve with a straw."
  ],
  "attributions": [
    {
      "relation": "recipe author",
      "source": "Eryn Reece"
    },
    {
      "relation": "bar",
      "source": "Death & Co",
      "location": "New York, NY"
    }
  ],
  "refs": [
