      "type": "bitter",
      "quantity": {
        "amount": 2,
        "unit": "dash"
      }
    },
    {
      "name": "Orange juice",
      "type": "juice",
      "quantity": {
        "amount": 0.5,
        "unit": "oz"
      }
    },
    {
