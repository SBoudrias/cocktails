{
  "$schema": "../../../../schemas/recipe.schema.json",
  "name": "Apple Peas Highball",
  "preparation": "built",
  "served_on": "ice cubes",
  "glassware": "highball",
  "ingredients": [
    {
      "name": "Apple-peas cordial",
      "type": "other",
      "quantity": {
        "amount": 5,
        "unit": "oz"
      }
    },
    {
      "name": "Poire Williams",
      "type": "category",
      "quantity": {
        "amount": 0.5,
        "unit": "oz"
      }
    },
    {
      "name": "Gin",
      "type": "category",
      "quantity": {
        "amount": 1.5,
        "unit": "oz"
      }
    }
  ],
  "instructions": [
    "Combine all ingredients in a cream whipper. Charge with CO₂, shake 10–15 seconds, vent, charge again and shake. Chill for a few minutes.",
    "Fill a highball glass with ice. Release pressure, open whipper and pour over ice. Garnish with a sugar snap pea."
  ],
